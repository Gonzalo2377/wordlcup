# Cloudflare Pages — reglas de caché
# Evita que los visitantes que repiten se queden con código o datos viejos.
# "no-cache" no significa "no guardar": el navegador revalida con el servidor
# (respuesta 304 si no cambió, muy rápida), así siempre ven la última versión.

/daily.json
  Cache-Control: no-cache

/*.html
  Cache-Control: no-cache

/*.js
  Cache-Control: no-cache

/*.jsx
  Cache-Control: no-cache

/*.css
  Cache-Control: no-cache

# Imágenes y assets de marca: pueden cachear (no cambian a menudo)
/brand/*
  Cache-Control: public, max-age=86400
